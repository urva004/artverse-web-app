# ═══════════════════════════════════════════════════
# ArtVerse — .gitignore
# ═══════════════════════════════════════════════════

# ─── Dependencies ────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build Outputs ───────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo

# ─── Turbo ───────────────────────────────────────
.turbo/

# ─── Environment Variables ───────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example

# ─── IDE / Editor ────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Prisma ──────────────────────────────────────
prisma/migrations/**/migration_lock.toml

# ─── Testing ─────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Logs ────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS Files ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ─── Debug ───────────────────────────────────────
*.pem

# ─── Vercel ──────────────────────────────────────
.vercel

# ─── Sentry ──────────────────────────────────────
.sentryclirc

# ─── Misc ────────────────────────────────────────
*.tgz
.cache/
