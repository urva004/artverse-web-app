{
  "name": "artverse",
  "version": "1.0.0",
  "private": true,
  "description": "ArtVerse — Art E-Commerce + Community Platform",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "@netlify/plugin-nextjs": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "styled-jsx": "^5.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.2.0",
  "allowScripts": {
    "bcrypt@5.1.1": true,
    "esbuild@0.27.7": true,
    "prisma@5.22.0": true,
    "prisma@6.19.3": true,
    "unrs-resolver@1.11.1": true,
    "@prisma/client@5.22.0": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "@prisma/engines@5.22.0": true
  }
}
